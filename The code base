print("Simple Calculator")

a = float(input("Enter first number: "))
b = float(input("Enter second number: "))

print("1:Add")
print("2:Subtract")

choice = input("Choose operation: ")

if choice == "1":
    print("Result:", a + b)

elif choice == "2":
    print("Result:", a - b)

else:
    print("Invalid choice)